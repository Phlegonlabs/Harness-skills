# .env.example
#
# Copy this file and rename it to .env.local, then fill in the real values.
# The scaffold also generates a local `.env.local` skeleton for fast follow-up work.
# Framework-specific variables should only be added when the corresponding milestone task introduces that framework.
# Warning: .env.local must not be committed to git (already configured in .gitignore)
# Warning: This file (.env.example) is committed to git with placeholder values only

# ── Application ─────────────────────────────────────────

NODE_ENV=development
# production / development / test

APP_URL=http://localhost:3000
# After deployment, change to the actual domain, e.g.: https://my-app.vercel.app

# ── Database ─────────────────────────────────────────────

DATABASE_URL=postgresql://user:password@localhost:5432/[PROJECT_NAME]_dev
# Use the above for local development
# For production, use the connection string from Vercel Postgres / Supabase / Neon

# ── Authentication ───────────────────────────────────────

AUTH_SECRET=your-auth-secret-here-min-32-chars
# Generate with any secure random-string method available in your environment
# Example: bun -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# ── AI Provider (if used) ────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...
# https://console.anthropic.com/

OPENAI_API_KEY=sk-...
# https://platform.openai.com/api-keys

# ── Third-party Services (fill in as needed) ─────────────

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@example.com

# CLOUDINARY_URL=cloudinary://...

# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# ── GitHub (Harness GitHub automation) ───────────────────

# GITHUB_TOKEN=ghp_...
# https://github.com/settings/tokens
# Not required if authenticated via gh auth login

# ── Feature Flags (optional) ─────────────────────────────

# ENABLE_AI_FEATURES=true
# ENABLE_ANALYTICS=false
